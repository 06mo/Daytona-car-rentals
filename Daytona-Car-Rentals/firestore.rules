rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helpers
    // ----------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------
    // Vehicles — public read, admin write
    // ----------------------------------------------------------------

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Bookings — owner or admin
    // ----------------------------------------------------------------

    match /bookings/{bookingId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Customers may only cancel their own booking (status → 'cancelled')
      // Admins may update any field
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.keys().hasOnly(
                resource.data.keys().concat(['status', 'cancellationReason', 'cancelledBy', 'cancelledAt', 'updatedAt'])
               ));

      allow delete: if false;

      match /checklists/{type} {
        allow read: if isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
              && resource.data.status == 'submitted');
        allow write: if isAdmin();
      }

      match /adjustments/{adjustmentId} {
        allow read: if isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
              && (resource.data.customerVisibleNote != null
                  || resource.data.status == 'pending'
                  || resource.data.status == 'paid'));
        allow write: if isAdmin();
      }
    }

    // ----------------------------------------------------------------
    // Users — self or admin
    // ----------------------------------------------------------------

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;

      // Documents sub-collection
      match /documents/{docId} {
        allow read: if isOwner(userId) || isAdmin();

        // Customers upload their own documents
        allow create, update: if isOwner(userId) || isAdmin();

        allow delete: if false;
      }
    }

    // ----------------------------------------------------------------
    // Extras pricing — public read, admin write
    // ----------------------------------------------------------------

    match /extras_pricing/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /protection_pricing/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing_rules/{ruleId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    match /promo_codes/{promoId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /app_settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /insurance_verifications/{verificationId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /coverage_decisions/{decisionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /policy_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /claims_evidence/{evidenceId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rental_agreements/{agreementId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ----------------------------------------------------------------
    // Audit logs — admin read, server write only
    // ----------------------------------------------------------------

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
